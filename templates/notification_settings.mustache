{{!
    @template mod_task/notification_settings

    The per-user "Notification settings" panel shown above the Task description.
    A Bootstrap button group selects one notification preference; clicking a
    button is handled by mod_task/view, which saves it via web service.

    Data attributes required for JS:
    * data-region="task-notify-settings"
    * data-cmid
    * data-action="set-notify-pref" and data-pref on each button

    Context variables required for this template:
    * cmid (int) the Task course module id
    * options (array) of { value (int), label (string), active (bool) }

    Example context (json):
    {
        "cmid": 12,
        "options": [
            {"value": 0, "label": "Mute notifications (except for Teacher replies)", "active": false},
            {"value": 1, "label": "All new responses", "active": false},
            {"value": 2, "label": "All new responses and replies", "active": true},
            {"value": 3, "label": "All new replies to my response only", "active": false}
        ]
    }
}}
<div class="mod-task-notification-settings" data-region="task-notify-settings" data-cmid="{{cmid}}">
  <div class="mod-task-notification-row d-flex flex-wrap justify-content-end align-items-center">
    <div class="dropdown">
      <button class="btn btn-secondary btn-sm dropdown-toggle" type="button" data-toggle="dropdown" aria-expanded="false">{{#str}}notificationpreferences, mod_task{{/str}}</button>
      <div class="dropdown-menu dropdown-menu-right">
      {{#options}}
        <button type="button" class="dropdown-item{{#active}} active{{/active}}"
          data-action="set-notify-pref" data-pref="{{value}}"
          aria-pressed="{{#active}}true{{/active}}{{^active}}false{{/active}}">{{label}}</button>
      {{/options}}
      </div>
    </div>
  </div>
</div>
