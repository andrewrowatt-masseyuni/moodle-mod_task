{{!
    @template mod_task/task

    The live Task shell rendered into the placeholder by mod_task/view.

    Beneath the Task description and Teacher response, a dedicated "Your response"
    panel either offers the composer (before the viewer has responded) or holds
    the viewer's own response and replies as a collapsible panel. Below it, an
    "Other responses" area lists everyone else's responses, each as its own
    collapsible panel; mod_task/view shows four at a time and loads more as the
    area is scrolled.

    Data attributes required for JS:
    * data-region="task-root"
    * data-region="your-response-posts" (own response panels are injected here)
    * data-region="responses-scroll" (the scrollable other-responses viewport)
    * data-region="posts" (other response panels are injected here)

    Context variables required for this template: see mod_task\manager::get_task_view().

    Example context (json):
    {
        "taskid": 7,
        "name": "Reflect on the reading",
        "showdescription": true,
        "taskdescription": "<p>What stood out to you?</p>",
        "canrespond": true,
        "canaddresponse": true,
        "shownotificationsettings": true,
        "notificationsettings": {
            "cmid": 12,
            "options": [
                {"value": 0, "label": "Mute all notifications", "active": false},
                {"value": 2, "label": "All new responses and replies", "active": true}
            ]
        },
        "canviewall": false,
        "cananonymous": true,
        "hasresponded": false,
        "canseeresponses": false,
        "showallresponsesheading": false,
        "showteacherresponse": false,
        "showteacherresponsenote": false,
        "teacherresponse": "",
        "teacherresponseismodelanswer": false,
        "postcount": 0,
        "currentuseravatar": "<img class=\"userpicture\" src=\"https://example.com/u.png\" alt=\"\">",
        "currentuserprofileurl": "https://example.com/user/profile.php?id=2"
    }
}}
<div class="mod-task-activity" data-region="task-root" data-taskid="{{taskid}}">

  {{#showdescription}}
    {{#shownotificationsettings}}
      {{#notificationsettings}}
        {{> mod_task/notification_settings }}
      {{/notificationsettings}}
    {{/shownotificationsettings}}
    {{> mod_task/description }}
  {{/showdescription}}

  {{#showteacherresponse}}
    <div class="mod-task-teacher-response mu-c4l c4l-mu-activities {{^teacherresponseismodelanswer}}c4lv-mu-comment c4lv-mu-comment1 c4l-mu-color-yellow-variant{{/teacherresponseismodelanswer}}{{#teacherresponseismodelanswer}}c4lv-mu-checkmark c4lv-mu-checkmark1 c4l-mu-color-green-variant{{/teacherresponseismodelanswer}}" data-region="teacher-response">
      <div class="mod-task-teacher-response-header d-flex justify-content-between">
        <h2 class="h5 mod-task-teacher-response-title mb-0">{{#str}}teacherresponseheading, mod_task{{/str}}</h2>
        {{#teacherresponseismodelanswer}}
          <span class="badge badge-success mod-task-model-badge">{{#str}}modelanswer, mod_task{{/str}}</span>
        {{/teacherresponseismodelanswer}}
      </div>
      <div class="mod-task-teacher-response-body">{{{teacherresponse}}}</div>
      {{#showteacherresponsenote}}
      <div class="mod-task-teacher-response-note pt-2 mt-3 d-flex align-items-center small">
        <i class="fa-solid fa-eye-slash mr-2"></i>{{#str}}teacherresponsestaffnote, mod_task{{/str}}</div>
      {{/showteacherresponsenote}}
    </div>
  {{/showteacherresponse}}

  {{^canseeresponses}}
    <div class="mod-task-gating-notice mu-c4l c4l-mu-activities c4lv-mu-information c4lv-mu-information1 c4l-mu-color-yellow-variant" role="note" data-region="gating-notice">
      {{#str}}mustrespondfirst, mod_task{{/str}}
    </div>
  {{/canseeresponses}}

  {{#canrespond}}
    <section class="mod-task-your-response" data-region="your-response">
      {{#canaddresponse}}
      <h2 class="h5 mod-task-section-heading">{{#str}}yourresponseheading, mod_task{{/str}}</h2>
        <div class="mod-task-composer" data-region="composer">
          <div class="mod-task-composer-row">
            <div class="mod-task-post-avatar" data-region="composer-avatar">
              {{#currentuserprofileurl}}<a href="{{currentuserprofileurl}}">{{{currentuseravatar}}}</a>{{/currentuserprofileurl}}
              {{^currentuserprofileurl}}{{{currentuseravatar}}}{{/currentuserprofileurl}}
            </div>
            <div class="mod-task-composer-main">
              <div class="mod-task-composer-expanded" data-region="composer-expanded">
                <div class="mod-task-editor" data-region="editor"></div>
                <div class="mod-task-composer-actions">
                  {{#cananonymous}}
                    <div class="form-check mod-task-anon-check">
                      <input class="form-check-input" type="checkbox" id="mod-task-anon-{{taskid}}" data-region="anonymous-toggle">
                      <label class="form-check-label " for="mod-task-anon-{{taskid}}">
                        {{#str}}respondanonymously, mod_task{{/str}}
                      </label>
                    </div>
                  {{/cananonymous}}
                  <button type="button" class="btn btn-primary" data-action="submit-compose">{{#str}}post, mod_task{{/str}}</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      {{/canaddresponse}}

      <div class="mod-task-your-response-posts" data-region="your-response-posts"></div>
    </section>
  {{/canrespond}}

  {{#canseeresponses}}
    <section class="mod-task-other-responses" data-region="other-responses">
      <div class="mod-task-responses-header">
        <div class="mod-task-responses-header-main">
          <h2 class="h5 mod-task-section-heading mb-0">{{#showallresponsesheading}}{{#str}}allresponsesheading, mod_task{{/str}}{{/showallresponsesheading}}{{^showallresponsesheading}}{{#str}}otherresponsesheading, mod_task{{/str}}{{/showallresponsesheading}}</h2>
          <span class="mod-task-responses-count" data-region="post-count"></span>
        </div>
        <div class="mod-task-sort">
          <button type="button" class="mod-task-sort-btn mod-task-sort-active" data-action="sort" data-sort="newest">{{#str}}newest, mod_task{{/str}}</button>
          <button type="button" class="mod-task-sort-btn" data-action="sort" data-sort="oldest">{{#str}}oldest, mod_task{{/str}}</button>
        </div>
      </div>

      <div class="mod-task-responses-scroll" data-region="responses-scroll">
        <div class="mod-task-posts" data-region="posts" aria-live="polite"></div>
      </div>

      <div class="mod-task-empty d-none" data-region="empty">
        {{#str}}nootherresponses, mod_task{{/str}}
      </div>
    </section>
  {{/canseeresponses}}
</div>
