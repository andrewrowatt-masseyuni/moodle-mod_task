{{!
    @template mod_task/description

    The Task description panel: a "Task description" heading followed by the
    formatted description (intro) HTML. Shared by the activity page header
    (mod_task\output\activity_header) and the live Task shell (mod_task/task),
    so the description renders identically wherever a Task appears.

    Context variables required for this template:
    * taskdescription (string) the formatted description (intro) HTML

    Example context (json):
    {
        "taskdescription": "<p>What stood out to you?</p>"
    }
}}
<div class="mod-task-description" data-region="task-description">
  <h4 class="h5 mod-task-description-heading">{{#str}}taskdescription, mod_task{{/str}}</h4>
  {{{taskdescription}}}
</div>
