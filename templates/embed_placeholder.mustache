{{!
    @template mod_task/embed_placeholder

    Skeleton container rendered on the activity page and in place of a
    {task:Name} token. The JS controller (mod_task/view) finds these via
    data-region="mod_task" and replaces the skeleton with the live Task.

    Data attributes required for JS:
    * data-region="mod_task"
    * data-cmid
    * data-contextid

    Context variables required for this template:
    * uid (string)
    * cmid (int)
    * contextid (int)

    Example context (json):
    {
        "uid": "mod_task_12_34",
        "cmid": 12,
        "contextid": 34
    }
}}
<div class="mod-task" data-region="mod_task" id="{{uid}}" data-cmid="{{cmid}}" data-contextid="{{contextid}}">
  <div class="mod-task-skeleton" aria-hidden="true">
    <div class="mod-task-skeleton-block mod-task-skeleton-title"></div>
    <div class="mod-task-skeleton-block mod-task-skeleton-content"></div>
    <div class="mod-task-skeleton-block mod-task-skeleton-trigger"></div>
  </div>
  <div class="sr-only">{{#str}}responseheading, mod_task{{/str}}</div>
</div>
