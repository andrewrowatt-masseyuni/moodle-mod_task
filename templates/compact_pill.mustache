{{!
    @template mod_task/compact_pill

    A single compact pill showing all reacted emojis followed by total count.

    Example context (json):
    {
        "hasanycount": true,
        "totalcount": 12,
        "reactedEmojis": [{"unicode": "👍"}, {"unicode": "❤️"}],
        "selected": true,
        "canreact": true
    }
}}
{{#hasanycount}}
    <button
        type="button"
        class="mod-task-reactions-pill mod-task-reactions-pill-compact{{#selected}} mod-task-reactions-selected{{/selected}}"
        data-action="open-picker"
        data-total-count="{{totalcount}}"
        aria-label="{{totalcount}} {{#str}} totalreactions, mod_task {{/str}}"
        {{^canreact}}disabled{{/canreact}}
    >
        <span class="mod-task-reactions-compact-emojis" aria-hidden="true">{{#reactedEmojis}}{{unicode}}{{/reactedEmojis}}</span>
        <span class="mod-task-reactions-count" data-region="reaction-count">{{totalcount}}</span>
    </button>
{{/hasanycount}}
