{{!
    @template mod_task/response_panel

    A collapsible Bootstrap card wrapping one top-level response and its replies.
    Used for both the dedicated "Your response" panel and each of the other
    responses. The response tree (the post and its replies) is rendered into
    [data-region="panel-body"] by mod_task/view.

    The hide/show labels are swapped purely by the .collapsed class Bootstrap
    toggles on the trigger (see styles.css), so the standard collapse data API
    drives the whole panel.

    Data attributes required for JS:
    * data-region="response-panel"
    * data-postid
    * data-region="panel-body" (where the post tree is injected)

    Context variables required for this template:
    * uid (string) unique fragment for the collapse target/header ids
    * postid (int) the top-level response id
    * title (string) optional header text shown beside the toggle (e.g. author name)
    * hidelabel (string) toggle text while expanded
    * showlabel (string) toggle text while collapsed
    * expanded (bool) whether the panel starts expanded
    * own (bool) whether this is the current user's own response

    Example context (json):
    {
        "uid": "7_42",
        "postid": 42,
        "title": "",
        "hidelabel": "Hide your response",
        "showlabel": "Show your response",
        "expanded": true,
        "own": true
    }
}}
<div class="card mod-task-response-panel {{#own}}mod-task-response-panel-own  mu-c4l c4l-mu-activities c4lv-mu-checkmark c4lv-mu-checkmark1 c4l-mu-color-green-variant{{/own}}"
  data-region="response-panel" data-postid="{{postid}}">
  {{#own}}<div class="card-header mod-task-response-panel-header d-flex justify-content-between align-items-center"
    id="mod-task-rph-{{uid}}">
    <h2 class="h5 mod-task-section-heading">{{#str}}yourresponseheading, mod_task{{/str}}</h2>
    {{#title}}<span class="mod-task-response-panel-title">{{title}}</span>{{/title}}
    {{^title}}<span></span>{{/title}}
    <button class="btn btn-sm btn-link mod-task-response-toggle{{^expanded}} collapsed{{/expanded}}" type="button"
      data-toggle="collapse" data-target="#mod-task-rpc-{{uid}}"
      aria-expanded="{{#expanded}}true{{/expanded}}{{^expanded}}false{{/expanded}}"
      aria-controls="mod-task-rpc-{{uid}}">
      <i class="fa fa-chevron-up mod-task-toggle-icon" aria-hidden="true"></i>
      <span class="mod-task-toggle-hide">{{hidelabel}}</span>
      <span class="mod-task-toggle-show">{{showlabel}}</span>
    </button>
  </div>{{/own}}
  <div id="mod-task-rpc-{{uid}}" class="collapse{{#expanded}} show{{/expanded}}"
    aria-labelledby="mod-task-rph-{{uid}}">
    <div class="card-body mod-task-response-panel-body" data-region="panel-body"></div>
  </div>
</div>
